---
interface Props {
  title: string;
  fullscreen?: boolean;
}

const { title, fullscreen = false } = Astro.props;
const currentPath = Astro.url.pathname;

const galeriesActive = currentPath === '/galeries' || currentPath.startsWith('/galeries/');
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Philippe Muraro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sofia+Sans+Extra+Condensed:wght@300&family=Bellota+Text:wght@300;400;700&family=Inter:wght@300;400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --color-bg: #1a1a1a;
        --color-text: #d0d0d0;
        --color-muted: #777;
        --color-border: #333;
        /* Logo « Philippe Muraro » */
        --font-display: 'Sofia Sans Extra Condensed', sans-serif;
        /* Titres de page et sous-titres */
        --font-title: 'Bellota Text', sans-serif;
        --color-title: #797979;
        --color-subtitle: #969696;
        --size-title: 48px;
        --size-subtitle: 16px;
        /* Interface : nav, boutons, légendes, formulaire */
        --font-body: 'Inter', system-ui, sans-serif;
        /* Textes littéraires : poèmes, textes de colonne de gauche */
        --font-serif: 'Instrument Serif', Georgia, serif;
        --nav-height: 90px;
        /* 1360 − 2×96 (h-padding) = 1168px utiles → 6 vignettes de 170px
           (6×170 + 5×20 de gouttière = 1120px) tiennent sur une ligne. */
        --max-width: 1360px;
        --h-padding: 6rem;
      }

      html, body {
        height: 100%;
      }

      body {
        font-family: var(--font-body);
        background-color: var(--color-bg);
        background-image:
          url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
        color: var(--color-text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ── HEADER ── */
      header {
        height: var(--nav-height);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: linear-gradient(to bottom, rgba(26,26,26,0.98) 60%, transparent 100%);
      }

      /* Le contenu du header s'aligne sur la colonne de contenu du site */
      .header-inner {
        height: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 var(--h-padding);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .logo {
        text-decoration: none;
        line-height: 1.1;
      }

      .logo .name {
        display: block;
        font-family: var(--font-display);
        font-size: 2.4rem;
        font-weight: 300;
        white-space: nowrap;
        letter-spacing: 0.06em;
        color: var(--color-text);
        text-transform: uppercase;
      }

      .logo .subtitle {
        display: block;
        font-family: var(--font-body);
        font-size: 0.7rem;
        font-weight: 300;
        letter-spacing: 0.28em;
        color: var(--color-muted);
        text-transform: uppercase;
        text-align: center;
        margin-top: 3px;
      }

      /* ── NAV ── */
      nav {
        display: flex;
        align-items: center;
      }

      nav a {
        text-decoration: none;
        color: var(--color-muted);
        font-family: var(--font-title);
        font-size: 1.05rem;
        font-weight: 400;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 0 1.6rem;
        transition: color 0.2s;
      }

      nav a:hover,
      nav a.active {
        color: var(--color-text);
      }

      nav .sep {
        color: #3a3a3a;
        font-size: 1rem;
        user-select: none;
      }

      /* ── HAMBURGER (mobile uniquement) ── */
      .nav-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        padding: 0;
        background: none;
        border: 0;
        cursor: pointer;
        z-index: 110;
      }
      .nav-toggle span {
        display: block;
        height: 2px;
        width: 26px;
        background: var(--color-text);
        transition: transform 0.3s ease, opacity 0.2s ease;
      }
      .nav-toggle[aria-expanded='true'] span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      .nav-toggle[aria-expanded='true'] span:nth-child(2) {
        opacity: 0;
      }
      .nav-toggle[aria-expanded='true'] span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      /* ── MAIN ── */
      main {
        flex: 1;
      }

      main.standard {
        max-width: var(--max-width);
        width: 100%;
        margin: 0 auto;
        padding: calc(var(--nav-height) + 3rem) var(--h-padding) 4rem;
      }

      main.fullscreen {
        padding-top: var(--nav-height);
      }

      /* ── FOOTER ── */
      footer {
        padding: 1rem var(--h-padding);
        text-align: right;
        font-size: 0.7rem;
        color: #333;
        letter-spacing: 0.08em;
        font-weight: 300;
      }

      /* Sur les pages fullscreen le footer se colle en bas sans prendre de place */
      body.is-fullscreen {
        position: relative;
      }

      body.is-fullscreen footer {
        position: fixed;
        bottom: 0;
        right: 0;
        padding: 1rem 2rem;
        background: transparent;
        z-index: 100;
      }

      /* Tablette (769–900px) : logo réduit pour tenir sur une ligne à côté de la nav */
      @media (max-width: 900px) {
        .logo .name { font-size: 1.9rem; }
        .logo .subtitle { font-size: 0.62rem; }
        nav a { padding: 0 1.1rem; }
      }

      /* Sous 800px (portable / paysage tablette) : titres réduits */
      @media (max-width: 800px) {
        :root { --size-title: 36px; }
      }

      /* ── MOBILE ── */
      @media (max-width: 768px) {
        :root {
          --h-padding: 1.25rem;
          --nav-height: 70px;
        }

        .logo .name { font-size: 1.4rem; }
        .logo .subtitle { font-size: 0.58rem; letter-spacing: 0.2em; }

        .nav-toggle { display: flex; }

        /* Nav en panneau déroulant plein largeur */
        nav {
          position: fixed;
          top: var(--nav-height);
          left: 0;
          right: 0;
          flex-direction: column;
          align-items: stretch;
          background: rgba(20, 20, 20, 0.98);
          backdrop-filter: blur(6px);
          border-top: 1px solid var(--color-border);
          padding: 0.5rem 0;
          transform: translateY(-12px);
          opacity: 0;
          visibility: hidden;
          transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
        }
        nav.open {
          transform: translateY(0);
          opacity: 1;
          visibility: visible;
        }
        nav a {
          padding: 1rem var(--h-padding);
          font-size: 1rem;
          border-bottom: 1px solid #262626;
        }
        nav .sep { display: none; }

        main.standard {
          padding: calc(var(--nav-height) + 2rem) var(--h-padding) 3rem;
        }
      }
    </style>
  </head>
  <body class={fullscreen ? 'is-fullscreen' : ''}>
    <header>
      <div class="header-inner">
      <a href="/" class="logo">
        <span class="name">Philippe Muraro</span>
        <span class="subtitle">Photographe</span>
      </a>

      <button id="nav-toggle" class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="site-nav">
        <span></span><span></span><span></span>
      </button>

      <nav id="site-nav">
        <a href="/galeries" class={galeriesActive ? 'active' : ''}>Galeries</a>
        <span class="sep">|</span>
        <a href="/textimages" class={currentPath === '/textimages' ? 'active' : ''}>Textimages</a>
        <span class="sep">|</span>
        <a href="/bio" class={currentPath === '/bio' ? 'active' : ''}>Bio</a>
        <span class="sep">|</span>
        <a href="/contact" class={currentPath === '/contact' ? 'active' : ''}>Contact</a>
      </nav>
      </div>
    </header>

    <main class={fullscreen ? 'fullscreen' : 'standard'}>
      <slot />
    </main>

    <footer>
      <p>jbraczyk 2026</p>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const nav = document.getElementById('site-nav');
      toggle?.addEventListener('click', () => {
        const open = nav?.classList.toggle('open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      // Ferme le menu quand on clique un lien
      nav?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => {
          nav.classList.remove('open');
          toggle?.setAttribute('aria-expanded', 'false');
        }),
      );
    </script>
  </body>
</html>
