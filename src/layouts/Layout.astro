---
interface Props {
  title: string;
  fullscreen?: boolean;
}

const { title, fullscreen = false } = Astro.props;
const currentPath = Astro.url.pathname;

const galeriesActive = currentPath === '/galeries' || currentPath.startsWith('/galeries/');
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Philippe Muraro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@600;700&family=Lato:wght@300;400&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --color-bg: #1a1a1a;
        --color-text: #d0d0d0;
        --color-muted: #777;
        --color-border: #333;
        --font-display: 'Oswald', sans-serif;
        --font-body: 'Lato', sans-serif;
        --nav-height: 90px;
        --max-width: 1200px;
        --h-padding: 6rem;
      }

      html, body {
        height: 100%;
      }

      body {
        font-family: var(--font-body);
        background-color: var(--color-bg);
        background-image:
          url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
        color: var(--color-text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ── HEADER ── */
      header {
        height: var(--nav-height);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 var(--h-padding);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: linear-gradient(to bottom, rgba(26,26,26,0.98) 60%, transparent 100%);
      }

      .logo {
        text-decoration: none;
        line-height: 1.1;
      }

      .logo .name {
        display: block;
        font-family: var(--font-display);
        font-size: 1.7rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: var(--color-text);
        text-transform: uppercase;
      }

      .logo .subtitle {
        display: block;
        font-family: var(--font-body);
        font-size: 0.65rem;
        font-weight: 300;
        letter-spacing: 0.28em;
        color: var(--color-muted);
        text-transform: uppercase;
        text-align: center;
        margin-top: 3px;
      }

      /* ── NAV ── */
      nav {
        display: flex;
        align-items: center;
      }

      nav a {
        text-decoration: none;
        color: var(--color-muted);
        font-family: var(--font-body);
        font-size: 0.92rem;
        font-weight: 400;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 0 1.6rem;
        transition: color 0.2s;
      }

      nav a:hover,
      nav a.active {
        color: var(--color-text);
      }

      nav .sep {
        color: #3a3a3a;
        font-size: 1rem;
        user-select: none;
      }

      /* ── MAIN ── */
      main {
        flex: 1;
      }

      main.standard {
        max-width: var(--max-width);
        width: 100%;
        margin: 0 auto;
        padding: calc(var(--nav-height) + 3rem) var(--h-padding) 4rem;
      }

      main.fullscreen {
        padding-top: var(--nav-height);
      }

      /* ── FOOTER ── */
      footer {
        padding: 1rem var(--h-padding);
        text-align: right;
        font-size: 0.7rem;
        color: #333;
        letter-spacing: 0.08em;
        font-weight: 300;
      }

      /* Sur les pages fullscreen le footer se colle en bas sans prendre de place */
      body.is-fullscreen {
        position: relative;
      }

      body.is-fullscreen footer {
        position: fixed;
        bottom: 0;
        right: 0;
        padding: 1rem 2rem;
        background: transparent;
        z-index: 100;
      }
    </style>
  </head>
  <body class={fullscreen ? 'is-fullscreen' : ''}>
    <header>
      <a href="/" class="logo">
        <span class="name">Philippe Muraro</span>
        <span class="subtitle">Photographe</span>
      </a>

      <nav>
        <a href="/galeries" class={galeriesActive ? 'active' : ''}>Galeries</a>
        <span class="sep">|</span>
        <a href="/textimages" class={currentPath === '/textimages' ? 'active' : ''}>Textimages</a>
        <span class="sep">|</span>
        <a href="/bio" class={currentPath === '/bio' ? 'active' : ''}>Bio</a>
        <span class="sep">|</span>
        <a href="/contact" class={currentPath === '/contact' ? 'active' : ''}>Contact</a>
      </nav>
    </header>

    <main class={fullscreen ? 'fullscreen' : 'standard'}>
      <slot />
    </main>

    <footer>
      <p>jbraczyk 2026</p>
    </footer>
  </body>
</html>
