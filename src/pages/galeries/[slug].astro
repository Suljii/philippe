---
import Layout from "../../layouts/Layout.astro";
import { sanityClient, imgSrc, imgSrcSet } from "../../lib/sanity";

const CARD_WIDTHS = [170, 340, 510];
const CARD_SIZES = "170px";
const FULL_WIDTHS = [1000, 1600, 2000, 2600, 3200];
const FULL_SIZES = "92vw";

export const prerender = false;

const { slug } = Astro.params;

const galerie = await sanityClient.fetch(
  `
  *[_type == "galerie" && slug.current == $slug][0] {
    titreHomepage,
    titrePage,
    nom,
    intro,
    texte,
    "pdfUrl": pdf.asset->url,
    "sousGaleries": *[_type == "galerie" && parent._ref == ^._id] | order(ordre asc) {
      titreHomepage,
      nom,
      "slug": slug.current,
      "couverture": coalesce(images[0].image, images[0].miniature),
      "lqip": coalesce(images[0].image.asset->metadata.lqip, images[0].miniature.asset->metadata.lqip)
    },
    images[] {
      titre,
      image,
      "lqip": image.asset->metadata.lqip
    }
  }
`,
  { slug },
);

if (!galerie) return Astro.redirect("/404");

const estCategorie = (galerie.sousGaleries?.length ?? 0) > 0;
const titre = galerie.titrePage || galerie.nom || galerie.titreHomepage;
const aTexte = !!galerie.texte;
---

<Layout title={titre}>
  <style>
    .retour {
      display: inline-block;
      margin-bottom: 2rem;
      font-size: 0.72rem;
      color: #555;
      text-decoration: none;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .retour:hover { color: #d0d0d0; }

    .galerie-header { margin-bottom: 3rem; }

    h1 {
      font-family: 'Oswald', sans-serif;
      font-size: 2rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #d0d0d0;
      margin-bottom: 0.9rem;
    }

    .intro {
      font-size: 1rem;
      color: #888;
      line-height: 1.75;
      max-width: 640px;
      font-weight: 300;
      margin-bottom: 0.75rem;
      white-space: pre-line;
    }

    .pdf-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      margin: 0.35rem 0 1.25rem;
      padding: 0.65rem 1.4rem;
      border: 1px solid #3a3a3a;
      color: #aaa;
      background: transparent;
      text-decoration: none;
      font-size: 0.76rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }
    .pdf-btn:hover {
      color: #e8e8e8;
      border-color: #777;
      background: rgba(255, 255, 255, 0.04);
    }
    .pdf-icon {
      font-size: 0.95rem;
      line-height: 1;
    }

    /* Mise en page avec texte de gauche */
    .layout-texte {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 3rem;
      align-items: start;
    }
    .texte-gauche {
      font-size: 0.95rem;
      line-height: 1.8;
      color: #999;
      font-weight: 300;
      white-space: pre-line;
      position: sticky;
      top: calc(var(--nav-height) + 2rem);
    }
    @media (max-width: 800px) {
      .layout-texte { grid-template-columns: 1fr; gap: 2rem; }
      .texte-gauche { position: static; }
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, 170px);
      gap: 1.25rem;
    }

    .grid figure { margin: 0; width: 170px; }
    .photo {
      display: block;
      width: 170px;
      height: 170px;
      padding: 0;
      border: 0;
      background: none;
      cursor: zoom-in;
      overflow: hidden;
    }
    .grid figure img {
      width: 100%;
      display: block;
      aspect-ratio: 1/1;
      object-fit: cover;
      filter: brightness(0.9);
      transition: opacity 0.3s, transform 0.4s ease;
    }
    .photo:hover img { opacity: 0.85; transform: scale(1.03); }

    figcaption {
      margin-top: 0.4rem;
      font-size: 0.8rem;
      color: #777;
      letter-spacing: 0.05em;
      font-weight: 300;
    }

    /* Cartes de sous-galeries (vue catégorie) */
    .card { text-decoration: none; color: inherit; display: block; width: 170px; }
    .card img {
      width: 170px;
      height: 170px;
      object-fit: cover;
      display: block;
      filter: brightness(0.85);
      transition: opacity 0.4s;
    }
    .card:hover img { opacity: 0.65; }
    .card-info { padding: 0.6rem 0; }
    .card-info h2 {
      font-size: 0.82rem;
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #aaa;
    }

    /* ── Lightbox ── */
    .lightbox {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(10, 10, 10, 0.75);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease;
      backdrop-filter: blur(4px);
    }
    .lightbox.open { opacity: 1; visibility: visible; }

    .lb-stage {
      margin: 0;
      max-width: 92vw;
      max-height: 92vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
    }
    #lb-img {
      max-width: 92vw;
      max-height: 84vh;
      object-fit: contain;
      box-shadow: 0 10px 60px rgba(0, 0, 0, 0.6);
      transform: scale(0.97);
      transition: transform 0.3s ease;
    }
    .lightbox.open #lb-img { transform: scale(1); }
    #lb-caption {
      color: #bbb;
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      font-weight: 300;
      text-align: center;
      min-height: 1em;
    }

    .lb-close, .lb-nav {
      position: fixed;
      background: none;
      border: 0;
      color: #ddd;
      cursor: pointer;
      line-height: 1;
      transition: color 0.2s, transform 0.2s;
      user-select: none;
    }
    .lb-close:hover, .lb-nav:hover { color: #fff; }
    .lb-close {
      top: 1.2rem;
      right: 1.6rem;
      font-size: 2.6rem;
    }
    .lb-nav {
      top: 50%;
      transform: translateY(-50%);
      font-size: 3.5rem;
      padding: 0 1.2rem;
    }
    .lb-nav:hover { transform: translateY(-50%) scale(1.15); }
    .lb-prev { left: 0.5rem; }
    .lb-next { right: 0.5rem; }

    @media (max-width: 600px) {
      .lb-nav { font-size: 2.4rem; padding: 0 0.5rem; }
      .lb-close { font-size: 2rem; }
    }
  </style>

  <a href="/galeries" class="retour">← Galeries</a>

  <div class="galerie-header">
    <h1>{titre}</h1>
    {/* Bouton PDF : entre le titre et le texte */}
    {galerie.pdfUrl && (
      <a href={galerie.pdfUrl} target="_blank" rel="noopener" class="pdf-btn">
        <span class="pdf-icon">↓</span> Ouvrir le textimage (PDF)
      </a>
    )}
    {/* La description n'apparaît que sur la page de la galerie elle-même */}
    {galerie.intro && <p class="intro">{galerie.intro}</p>}
  </div>

  {estCategorie ? (
    <div class="grid">
      {galerie.sousGaleries.map((sg: any) => (
        <a href={`/galeries/${sg.slug}`} class="card">
          {sg.couverture && (
            <img
              src={imgSrc(sg.couverture, 340, { square: true })}
              srcset={imgSrcSet(sg.couverture, CARD_WIDTHS, { square: true })}
              sizes={CARD_SIZES}
              alt={sg.nom || sg.titreHomepage}
              loading="lazy"
              decoding="async"
              style={sg.lqip ? `background-image:url(${sg.lqip});background-size:cover;background-position:center` : undefined}
            />
          )}
          <div class="card-info">
            <h2>{sg.nom || sg.titreHomepage}</h2>
          </div>
        </a>
      ))}
    </div>
  ) : aTexte ? (
    <div class="layout-texte">
      <aside class="texte-gauche">{galerie.texte}</aside>
      <div class="grid">
        {galerie.images?.map((item: any) => (
          <figure>
            <button
              type="button"
              class="photo"
              data-full={imgSrc(item.image, 2000)}
              data-srcset={imgSrcSet(item.image, FULL_WIDTHS)}
              data-sizes={FULL_SIZES}
              data-caption={item.titre || ''}
            >
              <img
                src={imgSrc(item.image, 340, { square: true })}
                srcset={imgSrcSet(item.image, CARD_WIDTHS, { square: true })}
                sizes={CARD_SIZES}
                alt={item.titre || titre}
                loading="lazy"
                decoding="async"
                style={item.lqip ? `background-image:url(${item.lqip});background-size:cover;background-position:center` : undefined}
              />
            </button>
            {item.titre && <figcaption>{item.titre}</figcaption>}
          </figure>
        ))}
      </div>
    </div>
  ) : (
    <div class="grid">
      {galerie.images?.map((item: any) => (
        <figure>
          <button
            type="button"
            class="photo"
            data-full={imgSrc(item.image, 2000)}
            data-srcset={imgSrcSet(item.image, FULL_WIDTHS)}
            data-sizes={FULL_SIZES}
            data-caption={item.titre || ''}
          >
            <img
              src={imgSrc(item.image, 340, { square: true })}
              srcset={imgSrcSet(item.image, CARD_WIDTHS, { square: true })}
              sizes={CARD_SIZES}
              alt={item.titre || titre}
              loading="lazy"
              decoding="async"
              style={item.lqip ? `background-image:url(${item.lqip});background-size:cover;background-position:center` : undefined}
            />
          </button>
          {item.titre && <figcaption>{item.titre}</figcaption>}
        </figure>
      ))}
    </div>
  )}

  {/* ── Lightbox / modale plein écran ── */}
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <button class="lb-close" aria-label="Fermer">×</button>
    <button class="lb-nav lb-prev" aria-label="Précédent">‹</button>
    <button class="lb-nav lb-next" aria-label="Suivant">›</button>
    <figure class="lb-stage">
      <img id="lb-img" src="" alt="" />
      <figcaption id="lb-caption"></figcaption>
    </figure>
  </div>

  <script>
    const lb = document.getElementById('lightbox') as HTMLElement;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbCap = document.getElementById('lb-caption') as HTMLElement;
    const photos = Array.from(document.querySelectorAll<HTMLButtonElement>('.photo'));
    let index = -1;
    let preloadedAll = false;

    function preload(i: number) {
      const btn = photos[i];
      if (!btn) return;
      const img = new Image();
      if (btn.dataset.sizes) img.sizes = btn.dataset.sizes;
      if (btn.dataset.srcset) img.srcset = btn.dataset.srcset;
      img.src = btn.dataset.full || '';
    }

    function preloadAll() {
      if (preloadedAll) return;
      preloadedAll = true;
      const run = () => photos.forEach((_, i) => preload(i));
      if ('requestIdleCallback' in window) (window as any).requestIdleCallback(run);
      else setTimeout(run, 200);
    }

    function show(i: number) {
      if (i < 0) i = photos.length - 1;
      if (i >= photos.length) i = 0;
      index = i;
      const btn = photos[i];
      lbImg.srcset = btn.dataset.srcset || '';
      lbImg.sizes = btn.dataset.sizes || '';
      lbImg.src = btn.dataset.full || '';
      const cap = btn.dataset.caption || '';
      lbImg.alt = cap;
      lbCap.textContent = cap;
      // précharge les voisines pour une navigation instantanée
      preload(i + 1 >= photos.length ? 0 : i + 1);
      preload(i - 1 < 0 ? photos.length - 1 : i - 1);
    }

    function open(i: number) {
      show(i);
      lb.classList.add('open');
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      preloadAll();
    }

    function close() {
      lb.classList.remove('open');
      lb.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    photos.forEach((btn, i) => btn.addEventListener('click', () => open(i)));

    lb.querySelector('.lb-close')!.addEventListener('click', close);
    lb.querySelector('.lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); show(index - 1); });
    lb.querySelector('.lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); show(index + 1); });

    // Clic sur le fond (hors image) ferme
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(index - 1);
      else if (e.key === 'ArrowRight') show(index + 1);
    });
  </script>
</Layout>
