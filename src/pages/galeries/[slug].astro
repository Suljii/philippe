---
import Layout from "../../layouts/Layout.astro";
import { sanityClient, imgSrc, imgSrcSet } from "../../lib/sanity";

const CARD_WIDTHS = [170, 340, 510];
const CARD_SIZES = "170px";
const FULL_WIDTHS = [1000, 1600, 2000, 2600, 3200];
const FULL_SIZES = "92vw";

export const prerender = false;

const { slug } = Astro.params;

const galerie = await sanityClient.fetch(
  `
  *[_type == "galerie" && slug.current == $slug][0] {
    titreHomepage,
    titrePage,
    sousTitre,
    nom,
    intro,
    texte,
    "pdfUrl": pdf.asset->url,
    "sousGaleries": *[_type == "galerie" && parent._ref == ^._id] | order(ordre asc) {
      titreHomepage,
      nom,
      "slug": slug.current,
      images[] {
        titre,
        image,
        "lqip": image.asset->metadata.lqip
      }
    },
    images[] {
      titre,
      image,
      "lqip": image.asset->metadata.lqip
    }
  }
`,
  { slug },
);

if (!galerie) return Astro.redirect("/404");

const estCategorie = (galerie.sousGaleries?.length ?? 0) > 0;
const titre = galerie.titrePage || galerie.nom || galerie.titreHomepage;
const aTexte = !!galerie.texte;
---

<Layout title={titre}>
  <style>
    .retour {
      display: inline-block;
      margin-bottom: 2rem;
      font-size: 0.72rem;
      color: #555;
      text-decoration: none;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .retour:hover { color: #d0d0d0; }

    .galerie-header { margin-bottom: 3rem; }

    h1 {
      font-family: var(--font-title);
      font-size: var(--size-title);
      font-weight: 300;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-title);
      margin-bottom: 0.9rem;
    }

    /* Texte à gauche, bouton PDF en face à droite, centrés verticalement */
    .header-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: wrap;
      margin: -0.3rem 0 0;
    }

    /* Le texte occupe toute la largeur restante : ligne entière s'il n'y a
       pas de bouton PDF, espace disponible sinon. */
    .header-texte {
      flex: 1;
      min-width: 0;
    }
    .header-texte > *:last-child { margin-bottom: 0; }

    .sous-titre-page {
      font-family: var(--font-title);
      font-size: 18px;
      font-weight: 300;
      letter-spacing: 0.08em;
      color: var(--color-subtitle);
      line-height: 1.2;
      margin: 0 0 0.5rem;
    }

    .intro {
      font-family: var(--font-title);
      font-size: 18px;
      color: var(--color-subtitle);
      line-height: 1.4;
      font-weight: 300;
      letter-spacing: 0.08em;
      margin-bottom: 0.75rem;
      white-space: pre-line;
    }

    .pdf-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      flex-shrink: 0;
      margin-left: auto;
      padding: 0.65rem 1.4rem;
      border: 1px solid #3a3a3a;
      color: #aaa;
      background: transparent;
      text-decoration: none;
      font-size: 0.76rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }
    .pdf-btn:hover {
      color: #e8e8e8;
      border-color: #777;
      background: rgba(255, 255, 255, 0.04);
    }
    .pdf-icon {
      font-size: 0.95rem;
      line-height: 1;
    }

    /* Mise en page avec texte de gauche */
    .layout-texte {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 3rem;
      align-items: start;
    }
    .texte-gauche {
      font-family: var(--font-serif);
      font-size: 18px;
      line-height: 1.45;
      color: #a0a0a0;
      font-weight: 400;
      white-space: pre-line;
      position: sticky;
      top: calc(var(--nav-height) + 2rem);
    }
    @media (max-width: 800px) {
      .layout-texte { grid-template-columns: 1fr; gap: 2rem; }
      .texte-gauche { position: static; }
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, 170px);
      gap: 1.25rem;
    }

    /* Sur mobile, les vignettes sont centrées horizontalement */
    @media (max-width: 768px) {
      .grid { justify-content: center; }
    }

    .grid figure { margin: 0; width: 170px; }
    .photo {
      display: block;
      width: 170px;
      height: 170px;
      padding: 0;
      border: 0;
      background: none;
      cursor: zoom-in;
      overflow: hidden;
    }
    .grid figure img {
      width: 100%;
      display: block;
      aspect-ratio: 1/1;
      object-fit: cover;
      filter: brightness(0.9);
      transition: opacity 0.3s, transform 0.4s ease;
    }
    .photo:hover img { opacity: 0.85; transform: scale(1.03); }

    figcaption {
      margin-top: 0.4rem;
      font-family: var(--font-title);
      font-size: 14px;
      color: #777;
      letter-spacing: 0.05em;
      font-weight: 300;
      text-align: center;
      width: 170px;
    }

    /* Vue catégorie : sections par sous-galerie */
    .sous-galerie { margin-bottom: 3rem; }
    .sous-galerie:last-child { margin-bottom: 0; }
    .sous-titre {
      font-family: var(--font-title);
      font-size: 18px;
      font-weight: 300;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-subtitle);
      line-height: 1.15;
      margin-bottom: 0.7rem;
    }

    /* ── Lightbox ── */
    .lightbox {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(10, 10, 10, 0.75);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease;
      backdrop-filter: blur(4px);
    }
    .lightbox.open { opacity: 1; visibility: visible; }

    .lb-stage {
      margin: 0;
      max-width: 92vw;
      max-height: 92vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
    }
    #lb-img {
      max-width: 92vw;
      max-height: 84vh;
      object-fit: contain;
      box-shadow: 0 10px 60px rgba(0, 0, 0, 0.6);
      transform: scale(0.97);
      transition: transform 0.3s ease;
    }
    .lightbox.open #lb-img { transform: scale(1); }
    #lb-caption {
      color: #bbb;
      font-family: var(--font-title);
      font-size: 14px;
      letter-spacing: 0.06em;
      font-weight: 300;
      text-align: center;
      min-height: 1em;
    }

    /* Modale PDF */
    .pdf-stage {
      width: min(1100px, 92vw);
      height: 88vh;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    #pdf-frame {
      flex: 1;
      width: 100%;
      border: 0;
      background: #1a1a1a;
      box-shadow: 0 10px 60px rgba(0, 0, 0, 0.6);
    }
    .pdf-dl {
      align-self: center;
      font-family: var(--font-title);
      font-size: 14px;
      letter-spacing: 0.08em;
      color: #bbb;
      text-decoration: none;
      transition: color 0.2s;
    }
    .pdf-dl:hover { color: #fff; }

    .lb-close, .lb-nav {
      position: fixed;
      background: none;
      border: 0;
      color: #ddd;
      cursor: pointer;
      line-height: 1;
      transition: color 0.2s, transform 0.2s;
      user-select: none;
    }
    .lb-close:hover, .lb-nav:hover { color: #fff; }
    .lb-close {
      top: 1.2rem;
      right: 1.6rem;
      font-size: 2.6rem;
    }
    .lb-nav {
      top: 50%;
      transform: translateY(-50%);
      font-size: 3.5rem;
      padding: 0 1.2rem;
    }
    .lb-nav:hover { transform: translateY(-50%) scale(1.15); }
    .lb-prev { left: 0.5rem; }
    .lb-next { right: 0.5rem; }

    @media (max-width: 600px) {
      .lb-nav { font-size: 2.4rem; padding: 0 0.5rem; }
      .lb-close { font-size: 2rem; }
    }
  </style>

  <a href="/galeries" class="retour">← Galeries</a>

  <div class="galerie-header">
    <h1>{titre}</h1>
    {/* Texte à gauche (sous-titre + description), bouton PDF en face à droite */}
    <div class="header-meta">
      <div class="header-texte">
        {galerie.sousTitre && <p class="sous-titre-page">{galerie.sousTitre}</p>}
        {/* La description n'apparaît que sur la page de la galerie elle-même */}
        {galerie.intro && <p class="intro">{galerie.intro}</p>}
      </div>
      {galerie.pdfUrl && (
        <a href={galerie.pdfUrl} target="_blank" rel="noopener" class="pdf-btn" id="pdf-open">
          <span class="pdf-icon">↓</span> Ouvrir le textimage (PDF)
        </a>
      )}
    </div>
  </div>

  {estCategorie ? (
    /* Catégorie : toutes les photos des sous-galeries, regroupées sous un intertitre */
    <div class="sections">
      {galerie.sousGaleries.map((sg: any) => (
        <section class="sous-galerie">
          <h2 class="sous-titre">{sg.nom || sg.titreHomepage}</h2>
          <div class="grid">
            {sg.images?.map((item: any) => (
              <figure>
                <button
                  type="button"
                  class="photo"
                  data-full={imgSrc(item.image, 2000)}
                  data-srcset={imgSrcSet(item.image, FULL_WIDTHS)}
                  data-sizes={FULL_SIZES}
                  data-caption={item.titre || ''}
                >
                  <img
                    src={imgSrc(item.image, 340, { square: true })}
                    srcset={imgSrcSet(item.image, CARD_WIDTHS, { square: true })}
                    sizes={CARD_SIZES}
                    alt={item.titre || sg.nom || sg.titreHomepage}
                    loading="lazy"
                    decoding="async"
                    style={item.lqip ? `background-image:url(${item.lqip});background-size:cover;background-position:center` : undefined}
                  />
                </button>
                {item.titre && <figcaption>{item.titre}</figcaption>}
              </figure>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : aTexte ? (
    <div class="layout-texte">
      <aside class="texte-gauche">{galerie.texte}</aside>
      <div class="grid">
        {galerie.images?.map((item: any) => (
          <figure>
            <button
              type="button"
              class="photo"
              data-full={imgSrc(item.image, 2000)}
              data-srcset={imgSrcSet(item.image, FULL_WIDTHS)}
              data-sizes={FULL_SIZES}
              data-caption={item.titre || ''}
            >
              <img
                src={imgSrc(item.image, 340, { square: true })}
                srcset={imgSrcSet(item.image, CARD_WIDTHS, { square: true })}
                sizes={CARD_SIZES}
                alt={item.titre || titre}
                loading="lazy"
                decoding="async"
                style={item.lqip ? `background-image:url(${item.lqip});background-size:cover;background-position:center` : undefined}
              />
            </button>
            {item.titre && <figcaption>{item.titre}</figcaption>}
          </figure>
        ))}
      </div>
    </div>
  ) : (
    <div class="grid">
      {galerie.images?.map((item: any) => (
        <figure>
          <button
            type="button"
            class="photo"
            data-full={imgSrc(item.image, 2000)}
            data-srcset={imgSrcSet(item.image, FULL_WIDTHS)}
            data-sizes={FULL_SIZES}
            data-caption={item.titre || ''}
          >
            <img
              src={imgSrc(item.image, 340, { square: true })}
              srcset={imgSrcSet(item.image, CARD_WIDTHS, { square: true })}
              sizes={CARD_SIZES}
              alt={item.titre || titre}
              loading="lazy"
              decoding="async"
              style={item.lqip ? `background-image:url(${item.lqip});background-size:cover;background-position:center` : undefined}
            />
          </button>
          {item.titre && <figcaption>{item.titre}</figcaption>}
        </figure>
      ))}
    </div>
  )}

  {/* ── Lightbox / modale plein écran ── */}
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <button class="lb-close" aria-label="Fermer">×</button>
    <button class="lb-nav lb-prev" aria-label="Précédent">‹</button>
    <button class="lb-nav lb-next" aria-label="Suivant">›</button>
    <figure class="lb-stage">
      <img id="lb-img" src="" alt="" />
      <figcaption id="lb-caption"></figcaption>
    </figure>
  </div>

  {/* ── Modale PDF (desktop uniquement) ── */}
  {galerie.pdfUrl && (
    <div id="pdf-modal" class="lightbox" aria-hidden="true">
      <button class="lb-close" id="pdf-close" aria-label="Fermer">×</button>
      <div class="pdf-stage">
        <iframe id="pdf-frame" title="Textimage (PDF)" src=""></iframe>
        <a href={galerie.pdfUrl} target="_blank" rel="noopener" class="pdf-dl">
          Ouvrir dans un nouvel onglet ↗
        </a>
      </div>
    </div>
  )}

  <script>
    const lb = document.getElementById('lightbox') as HTMLElement;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbCap = document.getElementById('lb-caption') as HTMLElement;
    const photos = Array.from(document.querySelectorAll<HTMLButtonElement>('.photo'));
    let index = -1;
    let preloadedAll = false;

    function preload(i: number) {
      const btn = photos[i];
      if (!btn) return;
      const img = new Image();
      if (btn.dataset.sizes) img.sizes = btn.dataset.sizes;
      if (btn.dataset.srcset) img.srcset = btn.dataset.srcset;
      img.src = btn.dataset.full || '';
    }

    function preloadAll() {
      if (preloadedAll) return;
      preloadedAll = true;
      const run = () => photos.forEach((_, i) => preload(i));
      if ('requestIdleCallback' in window) (window as any).requestIdleCallback(run);
      else setTimeout(run, 200);
    }

    function show(i: number) {
      if (i < 0) i = photos.length - 1;
      if (i >= photos.length) i = 0;
      index = i;
      const btn = photos[i];
      lbImg.srcset = btn.dataset.srcset || '';
      lbImg.sizes = btn.dataset.sizes || '';
      lbImg.src = btn.dataset.full || '';
      const cap = btn.dataset.caption || '';
      lbImg.alt = cap;
      lbCap.textContent = cap;
      // précharge les voisines pour une navigation instantanée
      preload(i + 1 >= photos.length ? 0 : i + 1);
      preload(i - 1 < 0 ? photos.length - 1 : i - 1);
    }

    function open(i: number) {
      show(i);
      lb.classList.add('open');
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      preloadAll();
    }

    function close() {
      lb.classList.remove('open');
      lb.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    photos.forEach((btn, i) => btn.addEventListener('click', () => open(i)));

    lb.querySelector('.lb-close')!.addEventListener('click', close);
    lb.querySelector('.lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); show(index - 1); });
    lb.querySelector('.lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); show(index + 1); });

    // Clic sur le fond (hors image) ferme
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(index - 1);
      else if (e.key === 'ArrowRight') show(index + 1);
    });

    // ── Modale PDF (desktop uniquement) ─────────────────────────────────
    // Sur mobile les navigateurs ne rendent pas les PDF en iframe : on laisse
    // le lien s'ouvrir normalement dans un nouvel onglet.
    const pdfBtn = document.getElementById('pdf-open') as HTMLAnchorElement | null;
    const pdfModal = document.getElementById('pdf-modal');
    const pdfFrame = document.getElementById('pdf-frame') as HTMLIFrameElement | null;

    if (pdfBtn && pdfModal && pdfFrame) {
      const surMobile = () =>
        window.matchMedia('(max-width: 900px)').matches ||
        window.matchMedia('(pointer: coarse)').matches;

      const fermerPdf = () => {
        pdfModal.classList.remove('open');
        pdfModal.setAttribute('aria-hidden', 'true');
        pdfFrame.src = ''; // libère le lecteur PDF
        document.body.style.overflow = '';
      };

      pdfBtn.addEventListener('click', (e) => {
        if (surMobile()) return; // comportement natif : nouvel onglet
        e.preventDefault();
        pdfFrame.src = pdfBtn.href;
        pdfModal.classList.add('open');
        pdfModal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      });

      document.getElementById('pdf-close')?.addEventListener('click', fermerPdf);
      pdfModal.addEventListener('click', (e) => { if (e.target === pdfModal) fermerPdf(); });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && pdfModal.classList.contains('open')) fermerPdf();
      });
    }
  </script>
</Layout>
