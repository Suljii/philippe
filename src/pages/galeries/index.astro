---
import Layout from "../../layouts/Layout.astro";
import { sanityClient, imgSrc, imgSrcSet } from "../../lib/sanity";

const CARD_WIDTHS = [170, 340, 510];
const CARD_SIZES = "170px";

// Galeries de premier niveau uniquement (catégories + galeries simples).
// Les sous-galeries (ex. les golfs) n'apparaissent PAS ici.
const galeries = await sanityClient.fetch(`
  *[_type == "galerie" && !defined(parent)] | order(ordre asc) {
    titreHomepage,
    "slug": slug.current,
    "couverture": coalesce(
      images[0].image,
      *[_type == "galerie" && parent._ref == ^._id] | order(ordre asc)[0].images[0].image
    ),
    "lqip": coalesce(
      images[0].image.asset->metadata.lqip,
      *[_type == "galerie" && parent._ref == ^._id] | order(ordre asc)[0].images[0].image.asset->metadata.lqip
    )
  }
`);
---

<Layout title="Galeries">
  <style>
    .section-label {
      font-family: var(--font-title);
      font-size: var(--size-title);
      font-weight: 300;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-title);
      margin-bottom: 1.25rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, 170px);
      gap: 1.25rem;
    }

    /* Sur mobile, les vignettes sont centrées horizontalement */
    @media (max-width: 768px) {
      .grid { justify-content: center; }
    }

    .card { width: 170px; }
    .card img { width: 170px; height: 170px; }

    .card {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .card img {
      width: 100%;
      aspect-ratio: 1/1;
      object-fit: cover;
      display: block;
      filter: brightness(0.85);
      transition: opacity 0.4s;
    }

    .card:hover img {
      opacity: 0.65;
    }

    .card-info {
      padding: 0;
    }

    .card-info h2 {
      font-family: var(--font-title);
      font-size: var(--size-subtitle);
      font-weight: 400;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-subtitle);
      text-align: center;
      /* line-height 1 supprime l'interligne au-dessus des capitales
         (Bellota Text a de grandes hampes). Augmenter margin-top écarte
         le titre de la vignette. */
      line-height: 1;
      margin-top: 0.3rem;
    }

    .vide {
      color: #444;
      font-size: 0.85rem;
      letter-spacing: 0.1em;
    }
  </style>

  <p class="section-label">Galeries</p>

  {galeries.length === 0 ? (
    <p class="vide">Aucune galerie disponible.</p>
  ) : (
    <div class="grid">
      {galeries.map((galerie: any) => (
        <a href={`/galeries/${galerie.slug}`} class="card">
          {galerie.couverture && (
            <img
              src={imgSrc(galerie.couverture, 340, { square: true })}
              srcset={imgSrcSet(galerie.couverture, CARD_WIDTHS, { square: true })}
              sizes={CARD_SIZES}
              alt={galerie.titreHomepage}
              loading="lazy"
              decoding="async"
              style={galerie.lqip ? `background-image:url(${galerie.lqip});background-size:cover;background-position:center` : undefined}
            />
          )}
          <div class="card-info">
            <h2>{galerie.titreHomepage}</h2>
          </div>
        </a>
      ))}
    </div>
  )}
</Layout>
