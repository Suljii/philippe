---
import Layout from "../layouts/Layout.astro";

// Image d'accueil fixe : déposer le fichier dans client/public/accueil.jpg
const photoAccueil = "/accueil.jpg";
---

<Layout title="Accueil" fullscreen={true}>
  <style>
    .hero {
      display: flex;
      align-items: center;
      justify-content: center;
      height: calc(100vh - 90px);
      padding: 2.5rem 6rem;
    }

    .hero-frame {
      height: 100%;
      max-width: 1000px;
      width: 100%;
    }

    .hero-frame img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
  </style>

  <div class="hero">
    <div class="hero-frame">
      <img src={photoAccueil} alt="Philippe Muraro — Photographe" />
    </div>
  </div>
</Layout>
