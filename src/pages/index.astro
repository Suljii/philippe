---
import Layout from "../layouts/Layout.astro";

// Slider d'accueil : ajouter/retirer des chemins ici (fichiers dans client/public/).
// Pour l'instant la même photo 3 fois, en attendant les visuels définitifs.
const slides = ["/accueil.jpg", "/accueil.jpg", "/accueil.jpg"];

const INTERVALLE_MS = 5000; // durée d'affichage de chaque photo
---

<Layout title="Accueil" fullscreen={true}>
  <style>
    .hero {
      display: flex;
      align-items: center;
      justify-content: center;
      height: calc(100vh - 90px);
      padding: 2.5rem 6rem;
    }

    @media (max-width: 768px) {
      .hero {
        height: calc(100vh - 70px);
        padding: 1.25rem;
      }
    }

    .hero-frame {
      height: 100%;
      max-width: 1000px;
      width: 100%;
    }

    .slider {
      position: relative;
      display: block;
      width: 100%;
      height: 100%;
    }

    .slide {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      opacity: 0;
      transition: opacity 1.2s ease;
    }

    .slide.active {
      opacity: 1;
    }

    .slider:hover .slide.active {
      opacity: 0.85;
    }
  </style>

  <div class="hero">
    <div class="hero-frame">
      <a href="/galeries" aria-label="Voir les galeries" class="slider" id="slider">
        {slides.map((src, i) => (
          <img
            src={src}
            class={i === 0 ? "slide active" : "slide"}
            alt="Philippe Muraro — Photographe"
            decoding="async"
            loading={i === 0 ? "eager" : "lazy"}
          />
        ))}
      </a>
    </div>
  </div>

  <script define:vars={{ INTERVALLE_MS }}>
    const slides = document.querySelectorAll(".slide");
    if (slides.length > 1) {
      let index = 0;
      setInterval(() => {
        slides[index].classList.remove("active");
        index = (index + 1) % slides.length;
        slides[index].classList.add("active");
      }, INTERVALLE_MS);
    }
  </script>
</Layout>
