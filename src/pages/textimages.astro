---
import Layout from "../layouts/Layout.astro";
import { sanityClient, imgSrc, imgSrcSet } from "../lib/sanity";

const COVER_WIDTHS = [200, 400, 600];
const COVER_SIZES = "200px";

const textimages = await sanityClient.fetch(`
  *[_type == "galerie" && defined(pdf.asset)] | order(ordre asc) {
    "titre": titreHomepage,
    "slug": slug.current,
    intro,
    "pdfUrl": pdf.asset->url,
    "couverture": coalesce(images[0].image, images[0].miniature),
    "lqip": coalesce(images[0].image.asset->metadata.lqip, images[0].miniature.asset->metadata.lqip)
  }
`);
---

<Layout title="Textimages">
  <style>
    h1 {
      font-family: "Oswald", sans-serif;
      font-size: 2rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #d0d0d0;
      margin-bottom: 2.25rem;
    }

    .liste {
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }

    .textimage {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 2rem;
      align-items: start;
    }

    @media (max-width: 600px) {
      .textimage {
        grid-template-columns: 1fr;
        gap: 1rem;
        max-width: 320px;
      }
    }

    .textimage img {
      width: 100%;
      display: block;
      aspect-ratio: 2/3;
      object-fit: cover;
    }

    .textimage-info h2 {
      font-size: 1.1rem;
      font-weight: 500;
      margin-bottom: 0.5rem;
    }

    .textimage-info p {
      font-size: 1rem;
      color: #888;
      line-height: 1.75;
      margin-bottom: 1rem;
    }

    .liens {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .lien-galerie {
      font-size: 0.85rem;
      color: #aaa;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .lien-pdf {
      font-size: 0.85rem;
      color: #888;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .vide {
      color: #888;
      font-size: 0.9rem;
    }
  </style>

  <h1>Textimages</h1>

  {textimages.length === 0 ? (
    <p class="vide">Aucun textimage disponible pour le moment.</p>
  ) : (
    <div class="liste">
      {textimages.map((textimage: any) => (
        <div class="textimage">
          {textimage.couverture && (
            <img
              src={imgSrc(textimage.couverture, 400)}
              srcset={imgSrcSet(textimage.couverture, COVER_WIDTHS)}
              sizes={COVER_SIZES}
              alt={textimage.titre}
              loading="lazy"
              decoding="async"
              style={textimage.lqip ? `background-image:url(${textimage.lqip});background-size:cover;background-position:center` : undefined}
            />
          )}
          <div class="textimage-info">
            <h2>{textimage.titre}</h2>
            {textimage.intro && <p>{textimage.intro}</p>}
            <div class="liens">
              <a href={`/galeries/${textimage.slug}`} class="lien-galerie">
                Voir la galerie →
              </a>
              {textimage.pdfUrl && (
                <a href={textimage.pdfUrl} target="_blank" class="lien-pdf">
                  Télécharger le PDF
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  )}
</Layout>
